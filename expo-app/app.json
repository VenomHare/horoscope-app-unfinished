{
  "expo": {
    "name": "Horashtak",
    "slug": "hora-detector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "expoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Hora Detector sends alerts before selected hora starts and ends."
      },
      "bundleIdentifier": "com.venomhare.horashtak"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo-foreground.png",
        "backgroundImage": "./assets/images/logo-background.png",
        "monochromeImage": "./assets/images/logo-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.venomhare.horashtak"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Hora Detector to use your location to calculate sunrise and the active hora."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#F0A51A",
          "defaultChannel": "hora-alerts"
        }
      ],
      "./plugins/with-android-hora-widget",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-foreground.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3699d03-9f65-4685-b3e0-e8f56b452f6d"
      }
    },
    "owner": "venomhare-org"
  }
}
